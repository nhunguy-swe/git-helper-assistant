{
  "name": "git-helper-assistant",
  "displayName": "Git Helper Assistant",
  "description": "Git helper for beginners",
  "version": "0.0.2",
  "publisher": "your-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/nhunguy-swe/git-helper-assistant"
  },
  "homepage": "https://github.com/nhunguy-swe/git-helper-assistant",
  "icon": "GitHelperAssistant.png",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "SCM"
  ],
  "activationEvents": [
    "onCommand:git-helper-assistant.showCommands"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-helper-assistant.showCommands",
        "title": "Git Helper Assistant: Show Git Commands"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
